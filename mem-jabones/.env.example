# API Key de Resend para enviar emails (REQUERIDO)
# Obtén tu API key en: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email desde el cual se envían los mensajes (OPCIONAL - valor por defecto: onboarding@resend.dev)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Email donde recibirás los mensajes de contacto (OPCIONAL - valor por defecto: contacto@mem-jabones.com)
RESEND_TO_EMAIL=tu-email@gmail.com

# URL del sitio (OPCIONAL - para metadatos y SEO)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app
